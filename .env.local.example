# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API в Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>

# Project Settings → API → service_role key (СЕКРЕТНЫЙ — только server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App URL ────────────────────────────────────────────────────────────────────
# Для локальной разработки: http://localhost:3000
# Для production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Wazzup OAuth (необязательно — только для интеграции WhatsApp) ─────────────
# Партнёрский кабинет: https://cabinet.wazzup24.com
WAZZUP_CLIENT_ID=
WAZZUP_PARTNER_EMAIL=
WAZZUP_PARTNER_PASSWORD=

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=AD Pulse <noreply@yourdomain.com>
